(load "../cli.carp")
(load "Test.carp")
(use Test)

; a small git-like app reused by the subcommand tests below

(def commit-parser
  (=> (CLI.new @"record changes")
      (CLI.add &(CLI.str "message" "m" "commit message" true))))

(def push-parser
  (=> (CLI.new @"upload changes")
      (CLI.add &(CLI.bool "force" "f" "force the push"))
      (CLI.add-pos &(CLI.pos-str "remote" "the remote" false))))

(def git
  (=> (CLI.App.new @"a tiny git")
      (CLI.App.add "commit" &commit-parser)
      (CLI.App.add "push" &push-parser)))

; `CLI.parse-from` is internal, so the flat-parser regression tests below reach
; it through a one-subcommand `App`: prepend a dummy subcommand name, dispatch,
; and collapse the `Dispatch` back to the `Result` shape those assertions expect.
; This exercises exactly the same parse loop every subcommand routes through.
(defn flat-parse [p args]
  (let [app (=> (CLI.App.new @"wrap") (CLI.App.add "cmd" p))
        full (Array.concat &[[@"cmd"] @args])]
    (match (CLI.App.parse-from &app &full)
      (CLI.Dispatch.Parsed pair) (Result.Success @(Pair.b &pair))
      (CLI.Dispatch.Failure e) (Result.Error e)
      (CLI.Dispatch.CommandHelp _) (Result.Error @"")
      (CLI.Dispatch.AppHelp) (Result.Error @""))))

; ---------------------------------------------------------------------------
; Type tests
; ---------------------------------------------------------------------------

(deftest test
  ; --- Type.= ---

  (assert-true test
    (CLI.Type.= &(CLI.Type.Integer 42l) &(CLI.Type.Integer 42l))
    "Type.= equal integers")

  (assert-false test
    (CLI.Type.= &(CLI.Type.Integer 1l) &(CLI.Type.Integer 2l))
    "Type.= different integers")

  (assert-true test
    (CLI.Type.= &(CLI.Type.Floating 3.14) &(CLI.Type.Floating 3.14))
    "Type.= equal floats")

  (assert-false test
    (CLI.Type.= &(CLI.Type.Floating 1.0) &(CLI.Type.Floating 2.0))
    "Type.= different floats")

  (assert-true test
    (CLI.Type.= &(CLI.Type.Str @"hello") &(CLI.Type.Str @"hello"))
    "Type.= equal strings")

  (assert-false test
    (CLI.Type.= &(CLI.Type.Str @"a") &(CLI.Type.Str @"b"))
    "Type.= different strings")

  (assert-true test
    (CLI.Type.= &(CLI.Type.Boolean true) &(CLI.Type.Boolean true))
    "Type.= equal booleans true")

  (assert-true test
    (CLI.Type.= &(CLI.Type.Boolean false) &(CLI.Type.Boolean false))
    "Type.= equal booleans false")

  (assert-false test
    (CLI.Type.= &(CLI.Type.Boolean true) &(CLI.Type.Boolean false))
    "Type.= different booleans")

  (assert-true test
    (CLI.Type.= &(CLI.Type.None) &(CLI.Type.None))
    "Type.= both None")

  (assert-false test
    (CLI.Type.= &(CLI.Type.None) &(CLI.Type.Integer 0l))
    "Type.= None vs Integer")

  (assert-false test
    (CLI.Type.= &(CLI.Type.Integer 0l) &(CLI.Type.Str @"0"))
    "Type.= cross-type Integer vs Str")

  (assert-false test
    (CLI.Type.= &(CLI.Type.Boolean true) &(CLI.Type.Str @"true"))
    "Type.= cross-type Boolean vs Str")

  ; --- Type.str ---

  (assert-equal test
    "42"
    &(CLI.Type.str &(CLI.Type.Integer 42l))
    "Type.str integer")

  (assert-equal test
    "3.14"
    &(CLI.Type.str &(CLI.Type.Floating 3.14))
    "Type.str float")

  (assert-equal test
    "hello"
    &(CLI.Type.str &(CLI.Type.Str @"hello"))
    "Type.str string")

  (assert-equal test
    "true"
    &(CLI.Type.str &(CLI.Type.Boolean true))
    "Type.str boolean true")

  (assert-equal test
    "false"
    &(CLI.Type.str &(CLI.Type.Boolean false))
    "Type.str boolean false")

  (assert-equal test "none" &(CLI.Type.str &(CLI.Type.None)) "Type.str none")

  ; --- Type.format ---

  (assert-equal test
    "42"
    &(CLI.Type.format "%lld" &(CLI.Type.Integer 42l))
    "Type.format integer")

  (assert-equal test
    "3.140000"
    &(CLI.Type.format "%f" &(CLI.Type.Floating 3.14))
    "Type.format float")

  (assert-equal test
    "hello"
    &(CLI.Type.format "%s" &(CLI.Type.Str @"hello"))
    "Type.format string")

  (assert-equal test
    "true"
    &(CLI.Type.format "%s" &(CLI.Type.Boolean true))
    "Type.format boolean")

  (assert-equal test
    "none"
    &(CLI.Type.format "%s" &(CLI.Type.None))
    "Type.format none")

  ; --- Type.to-* conversions ---

  (assert-equal test
    42
    (CLI.Type.to-int (CLI.Type.Integer 42l))
    "Type.to-int from Integer")

  (assert-equal test
    0
    (CLI.Type.to-int (CLI.Type.Str @"x"))
    "Type.to-int from non-Integer")

  (assert-equal test
    42l
    (CLI.Type.to-long (CLI.Type.Integer 42l))
    "Type.to-long from Integer")

  (assert-equal test
    0l
    (CLI.Type.to-long (CLI.Type.None))
    "Type.to-long from non-Integer")

  (assert-equal test
    "hi"
    &(CLI.Type.to-str (CLI.Type.Str @"hi"))
    "Type.to-str from Str")

  (assert-equal test
    ""
    &(CLI.Type.to-str (CLI.Type.Integer 1l))
    "Type.to-str from non-Str")

  (assert-true test
    (CLI.Type.to-bool (CLI.Type.Boolean true))
    "Type.to-bool from Boolean true")

  (assert-false test
    (CLI.Type.to-bool (CLI.Type.Boolean false))
    "Type.to-bool from Boolean false")

  (assert-false test
    (CLI.Type.to-bool (CLI.Type.Str @"true"))
    "Type.to-bool from non-Boolean")

  (assert-equal test
    0.0
    (CLI.Type.to-double (CLI.Type.Floating 0.0))
    "Type.to-double zero")

  (assert-equal test
    0.0
    (CLI.Type.to-double (CLI.Type.Integer 0l))
    "Type.to-double from non-Floating")

  ; --- Type.zero ---

  (assert-true test
    (CLI.Type.= &(CLI.Type.None) &(CLI.Type.zero))
    "Type.zero is None")

  ; --- Tag.= ---

  (assert-true test
    (CLI.Tag.= &(CLI.Tag.TInteger) &(CLI.Tag.TInteger))
    "Tag.= equal Integer")

  (assert-true test
    (CLI.Tag.= &(CLI.Tag.TBoolean) &(CLI.Tag.TBoolean))
    "Tag.= equal Boolean")

  (assert-false test
    (CLI.Tag.= &(CLI.Tag.TInteger) &(CLI.Tag.TStr))
    "Tag.= different tags")

  ; --- Tag.to-type ---

  (assert-equal test
    "42"
    &(CLI.Type.str &(CLI.Tag.to-type (CLI.Tag.TInteger) "42"))
    "Tag.to-type Integer parses")

  (assert-equal test
    "hello"
    &(CLI.Type.str &(CLI.Tag.to-type (CLI.Tag.TStr) "hello"))
    "Tag.to-type Str passes through")

  (assert-equal test
    "true"
    &(CLI.Type.str &(CLI.Tag.to-type (CLI.Tag.TBoolean) "true"))
    "Tag.to-type Boolean true")

  (assert-equal test
    "true"
    &(CLI.Type.str &(CLI.Tag.to-type (CLI.Tag.TBoolean) "yes"))
    "Tag.to-type Boolean non-false is true")

  (assert-equal test
    "false"
    &(CLI.Type.str &(CLI.Tag.to-type (CLI.Tag.TBoolean) "false"))
    "Tag.to-type Boolean false")

  ; --- CmdMap ---

  (let [m (CLI.CmdMap.new)]
    (assert-false test
      (CLI.CmdMap.contains? &m "x")
      "CmdMap.contains? empty map"))

  (let-do [o (CLI.int "flag" "f" "desc" true)
           m (CLI.CmdMap.put-empty (CLI.CmdMap.new) &o)
           t (assert-true test
             (CLI.CmdMap.contains? &m "flag")
             "CmdMap.contains? by long name")]
    (set! t
          (assert-true &t
            (CLI.CmdMap.contains? &m "f")
            "CmdMap.contains? by short name"))
    (assert-false &t
      (CLI.CmdMap.contains? &m "other")
      "CmdMap.contains? missing key"))

  (let-do [o (CLI.str "name" "n" "a name" false)
           m (CLI.CmdMap.put-empty (CLI.CmdMap.new) &o)]
    (let-do [t (assert-false test
               (CLI.CmdMap.set? &m "name")
               "CmdMap.set? returns false when no value set")]
      (CLI.CmdMap.put! &m "name" "hello")
      (assert-true &t
        (CLI.CmdMap.set? &m "name")
        "CmdMap.set? returns true after put!")))

  (let-do [o (CLI.int "count" "c" "a count" false)
           m (CLI.CmdMap.put-empty (CLI.CmdMap.new) &o)]
    (CLI.CmdMap.put! &m "count" "10")
    (assert-equal test
      "10"
      &(CLI.Type.str &(CLI.CmdMap.get &m "count"))
      "CmdMap.get retrieves value after put!"))

  (let-do [o (CLI.str "mode" "m" "mode" false @"a" &[@"a" @"b"])
           m (CLI.CmdMap.put-empty (CLI.CmdMap.new) &o)]
    (CLI.CmdMap.put! &m "mode" "a")
    (let-do [t (assert-true test
               (CLI.CmdMap.in? &m
                               "mode"
                               &[(CLI.Type.Str @"a") (CLI.Type.Str @"b")])
               "CmdMap.in? value in options")]
      (CLI.CmdMap.put! &m "mode" "x")
      (assert-false &t
        (CLI.CmdMap.in? &m "mode" &[(CLI.Type.Str @"a") (CLI.Type.Str @"b")])
        "CmdMap.in? value not in options")))

  (let-do [o (CLI.int "flag" "f" "desc" false)
           m (CLI.CmdMap.put-empty (CLI.CmdMap.new) &o)]
    (let-do [t (assert-true test
               (CLI.CmdMap.type? &m "flag" &(CLI.Tag.TInteger))
               "CmdMap.type? correct type")]
      (assert-false &t
        (CLI.CmdMap.type? &m "flag" &(CLI.Tag.TStr))
        "CmdMap.type? wrong type")))

  (let [o (CLI.bool "verbose" "v" "be verbose")
        m (CLI.CmdMap.put-empty (CLI.CmdMap.new) &o)]
    (assert-true test
      (CLI.CmdMap.type? &m "verbose" &(CLI.Tag.TBoolean))
      "CmdMap.type? boolean"))

  ; --- CmdMap.to-map ---

  (let-do [o1 (CLI.int "flag" "f" "desc" false)
           o2 (CLI.str "name" "n" "desc" false)
           m (CLI.CmdMap.put-empty
             (CLI.CmdMap.put-empty (CLI.CmdMap.new) &o1)
             &o2)]
    (CLI.CmdMap.put! &m "flag" "5")
    (let-do [result (CLI.CmdMap.to-map &m)
             t (assert-true test
               (Map.contains? &result "flag")
               "CmdMap.to-map includes set values")]
      (assert-false &t
        (Map.contains? &result "name")
        "CmdMap.to-map excludes unset values")))

  ; --- Option construction ---

  (let-do [o (CLI.int "port" "p" "port number" true)
           t (assert-equal test
             "port"
             (CLI.Option.long &o)
             "Option int long name")]
    (set! t (assert-equal &t "p" (CLI.Option.short &o) "Option int short name"))
    (assert-true &t @(CLI.Option.required? &o) "Option int required"))

  (let-do [o (CLI.str "name" "n" "a name" false @"default")
           t (assert-false test
             @(CLI.Option.required? &o)
             "Option str not required")]
    (assert-true &t
      (Maybe.just? (CLI.Option.default &o))
      "Option str has default"))

  (let-do [o (CLI.bool "verbose" "v" "verbose output")
           t (assert-equal test
             "verbose"
             (CLI.Option.long &o)
             "Option bool long name")]
    (assert-false &t @(CLI.Option.required? &o) "Option bool not required"))

  (let [o (CLI.float "rate" "r" "rate" false 1.5)]
    (assert-true test
      (Maybe.just? (CLI.Option.default &o))
      "Option float has default"))

  ; --- Parser construction ---

  (let-do [p (=> (CLI.new @"test program")
                 (CLI.add &(CLI.int "port" "p" "port" true))
                 (CLI.add &(CLI.str "host" "h" "host" false)))]
    (let-do [t (assert-equal test
               "test program"
               (CLI.Parser.description &p)
               "Parser description")]
      (assert-equal &t
        2
        (Array.length (CLI.Parser.options &p))
        "Parser has two options")))

  ; --- Positional construction ---

  (let-do [pos (CLI.pos-str "source" "source file" true)
           t (assert-equal test
             "source"
             (CLI.Positional.name &pos)
             "Positional str name")]
    (set! t
          (assert-equal &t
            "source file"
            (CLI.Positional.description &pos)
            "Positional str description"))
    (assert-true &t @(CLI.Positional.required? &pos) "Positional str required"))

  (let [pos (CLI.pos-int "count" "item count" false)]
    (assert-false test
      @(CLI.Positional.required? &pos)
      "Positional int optional"))

  (let [pos (CLI.pos-float "rate" "processing rate" true)]
    (assert-true test
      @(CLI.Positional.required? &pos)
      "Positional float required"))

  ; --- Parser with positionals ---

  (let-do [p (=> (CLI.new @"test")
                 (CLI.add &(CLI.bool "verbose" "v" "verbose"))
                 (CLI.add-pos &(CLI.pos-str "src" "source" true))
                 (CLI.add-pos &(CLI.pos-str "dst" "destination" true)))]
    (let-do [t (assert-equal test
               1
               (Array.length (CLI.Parser.options &p))
               "Parser with positionals has one option")]
      (assert-equal &t
        2
        (Array.length (CLI.Parser.positionals &p))
        "Parser with positionals has two positionals")))

  ; --- Parser.values (initial CmdMap) ---

  (let-do [p (=> (CLI.new @"test")
                 (CLI.add &(CLI.int "a" "x" "desc" false))
                 (CLI.add &(CLI.str "b" "y" "desc" false)))
           m (CLI.Parser.values &p)]
    (let-do [t (assert-true test
               (CLI.CmdMap.contains? &m "a")
               "Parser.values populates first option")]
      (set! t
            (assert-true &t
              (CLI.CmdMap.contains? &m "b")
              "Parser.values populates second option"))
      (assert-false &t
        (CLI.CmdMap.set? &m "a")
        "Parser.values options start unset")))

  ; ---------------------------------------------------------------------------
  ; parse-from (explicit-array parsing, and regression coverage for the flat
  ; parser: a plain no-subcommand Parser must behave exactly as before)
  ; ---------------------------------------------------------------------------

  (let-do [p (=> (CLI.new @"flat")
                 (CLI.add &(CLI.int "flag" "f" "a flag" true))
                 (CLI.add &(CLI.str "name" "n" "a name" false @"anon")))
           res (flat-parse &p &[@"--flag" @"5" @"--name" @"veit"])]
    (match res
      (Result.Success m)
        (let-do [t (assert-equal test
                   "5"
                   &(CLI.Type.str &(Map.get &m "flag"))
                   "parse-from reads an int option")]
          (assert-equal &t
            "veit"
            &(CLI.Type.str &(Map.get &m "name"))
            "parse-from reads a string option"))
      (Result.Error _)
        (assert-true test false "parse-from unexpectedly errored")))

  (let-do [p (=> (CLI.new @"flat")
                 (CLI.add-pos &(CLI.pos-str "src" "source" true)))
           res (flat-parse &p &[@"in.txt"])]
    (match res
      (Result.Success m)
        (assert-equal test
          "in.txt"
          &(CLI.Type.str &(Map.get &m "src"))
          "parse-from reads a positional argument")
      (Result.Error _)
        (assert-true test false "parse-from positional unexpectedly errored")))

  (let-do [p (=> (CLI.new @"flat") (CLI.add &(CLI.int "flag" "f" "a flag" true)))
           res (flat-parse &p &[])]
    (match res
      (Result.Error e)
        (assert-equal test
          "Required option missing: --flag"
          &e
          "parse-from reports a missing required option")
      (Result.Success _)
        (assert-true test false "parse-from should have errored")))

  ; regression: a boolean flag in `--flag=value` form used to hang the parser
  ; forever (an inverted guard gave back a token that was never consumed) and
  ; ignored the value; it must terminate and honor the value
  (let-do [p (=> (CLI.new @"flat") (CLI.add &(CLI.bool "force" "f" "force")))
           res (flat-parse &p &[@"--force=false"])]
    (match res
      (Result.Success m)
        (assert-equal test
          "false"
          &(CLI.Type.str &(Map.get &m "force"))
          "parse-from honors --flag=false for a boolean (and terminates)")
      (Result.Error _)
        (assert-true test false "boolean --flag=false unexpectedly errored")))

  (let-do [p (=> (CLI.new @"flat") (CLI.add &(CLI.bool "force" "f" "force")))
           res (flat-parse &p &[@"--force=true"])]
    (match res
      (Result.Success m)
        (assert-equal test
          "true"
          &(CLI.Type.str &(Map.get &m "force"))
          "parse-from honors --flag=true for a boolean")
      (Result.Error _)
        (assert-true test false "boolean --flag=true unexpectedly errored")))

  ; regression: a bare boolean that is not the last token must not swallow the
  ; following token (the same inverted guard dropped it)
  (let-do [p (=> (CLI.new @"flat")
                 (CLI.add &(CLI.bool "force" "f" "force"))
                 (CLI.add-pos &(CLI.pos-str "file" "a file" false)))
           res (flat-parse &p &[@"--force" @"in.txt"])]
    (match res
      (Result.Success m)
        (let-do [t (assert-equal test
                   "true"
                   &(CLI.Type.str &(Map.get &m "force"))
                   "a bare boolean flag reads as true")]
          (assert-equal &t
            "in.txt"
            &(CLI.Type.str &(Map.get &m "file"))
            "a bare boolean does not swallow the following positional"))
      (Result.Error _)
        (assert-true test false "bare boolean + positional unexpectedly errored")))

  ; a bare `--` ends option parsing: every following token is a positional even
  ; if it begins with `-`
  (let-do [p (=> (CLI.new @"flat")
                 (CLI.add-pos &(CLI.pos-str "target" "a target" true)))
           res (flat-parse &p &[@"--" @"-x"])]
    (match res
      (Result.Success m)
        (assert-equal test
          "-x"
          &(CLI.Type.str &(Map.get &m "target"))
          "a bare -- routes the following -x into a positional")
      (Result.Error _)
        (assert-true test false "-- then -x unexpectedly errored")))

  ; a token after `--` is a positional even when it is shaped like a long option
  (let-do [p (=> (CLI.new @"flat")
                 (CLI.add-pos &(CLI.pos-str "target" "a target" true)))
           res (flat-parse &p &[@"--" @"--foo"])]
    (match res
      (Result.Success m)
        (assert-equal test
          "--foo"
          &(CLI.Type.str &(Map.get &m "target"))
          "a token after -- is a positional, not an unknown-option error")
      (Result.Error _)
        (assert-true test false "-- then --foo unexpectedly errored")))

  ; a token shaped like a negative number is a positional, not an unknown option
  (let-do [p (=> (CLI.new @"flat")
                 (CLI.add-pos &(CLI.pos-int "n" "a number" true)))
           res (flat-parse &p &[@"-5"])]
    (match res
      (Result.Success m)
        (assert-equal test
          "-5"
          &(CLI.Type.str &(Map.get &m "n"))
          "a negative-integer token fills a positional")
      (Result.Error _)
        (assert-true test
          false
          "negative-integer positional unexpectedly errored")))

  (let-do [p (=> (CLI.new @"flat")
                 (CLI.add-pos &(CLI.pos-float "rate" "a rate" true)))
           res (flat-parse &p &[@"-3.14"])]
    (match res
      (Result.Success m)
        (assert-equal test
          "-3.14"
          &(CLI.Type.str &(Map.get &m "rate"))
          "a negative-float token fills a positional")
      (Result.Error _)
        (assert-true test false "negative-float positional unexpectedly errored")))

  ; the negative-number-as-positional path is only for standalone tokens: an
  ; option that takes a value still consumes a following -5 as that value
  (let-do [p (=> (CLI.new @"flat")
                 (CLI.add &(CLI.int "offset" "o" "an offset" true)))
           res (flat-parse &p &[@"--offset" @"-5"])]
    (match res
      (Result.Success m)
        (assert-equal test
          "-5"
          &(CLI.Type.str &(Map.get &m "offset"))
          "a value-taking option consumes a following -5 as its value")
      (Result.Error _)
        (assert-true test false "--offset -5 unexpectedly errored")))

  ; integration: options before -- still parse, then -- ends option parsing so a
  ; trailing dash-prefixed token lands in a positional
  (let-do [p (=> (CLI.new @"flat")
                 (CLI.add &(CLI.int "offset" "o" "an offset" false))
                 (CLI.add-pos &(CLI.pos-str "target" "a target" true)))
           res (flat-parse &p &[@"--offset" @"5" @"--" @"-x"])]
    (match res
      (Result.Success m)
        (let-do [t (assert-equal test
                   "5"
                   &(CLI.Type.str &(Map.get &m "offset"))
                   "an option before -- still parses")]
          (assert-equal &t
            "-x"
            &(CLI.Type.str &(Map.get &m "target"))
            "-- ends options so the trailing -x is a positional"))
      (Result.Error _)
        (assert-true test false "option then -- then -x unexpectedly errored")))

  ; ---------------------------------------------------------------------------
  ; App / subcommands
  ; ---------------------------------------------------------------------------

  (assert-equal test
    2
    (Array.length (CLI.App.commands &git))
    "App registers two subcommands")

  (let-do [t (assert-true test
             (CLI.App.has? &git "commit")
             "App.has? finds a registered subcommand")]
    (assert-false &t
      (CLI.App.has? &git "nope")
      "App.has? rejects an unknown subcommand"))

  (let-do [res (CLI.App.parse-from &git &[@"commit" @"--message" @"hello"])]
    (match res
      (CLI.Dispatch.Parsed pair)
        (let-do [t (assert-equal test
                   "commit"
                   (Pair.a &pair)
                   "App dispatches to the commit subcommand")]
          (assert-equal &t
            "hello"
            &(CLI.Type.str &(Map.get (Pair.b &pair) "message"))
            "commit subcommand parses its own option"))
      _ (assert-true test false "commit dispatch unexpectedly errored")))

  (let-do [res (CLI.App.parse-from &git &[@"push" @"origin" @"--force"])]
    (match res
      (CLI.Dispatch.Parsed pair)
        (let-do [t (assert-equal test
                   "push"
                   (Pair.a &pair)
                   "App dispatches to the push subcommand")]
          (set! t
                (assert-equal &t
                  "origin"
                  &(CLI.Type.str &(Map.get (Pair.b &pair) "remote"))
                  "push subcommand parses its positional"))
          (assert-equal &t
            "true"
            &(CLI.Type.str &(Map.get (Pair.b &pair) "force"))
            "push subcommand parses its boolean flag"))
      _ (assert-true test false "push dispatch unexpectedly errored")))

  ; regression: the `--flag=value` boolean hang and value are reachable through a
  ; subcommand too, since App routes every subcommand's args through parse-from
  (let-do [res (CLI.App.parse-from &git &[@"push" @"--force=false"])]
    (match res
      (CLI.Dispatch.Parsed pair)
        (assert-equal test
          "false"
          &(CLI.Type.str &(Map.get (Pair.b &pair) "force"))
          "a subcommand honors --flag=false for a boolean (and terminates)")
      _
        (assert-true test
          false
          "subcommand boolean --flag=false unexpectedly errored")))

  (let-do [res (CLI.App.parse-from &git &[@"frobnicate"])]
    (match res
      (CLI.Dispatch.Failure e)
        (assert-equal test
          "Unknown subcommand: frobnicate"
          &e
          "App reports an unknown subcommand")
      _ (assert-true test false "unknown subcommand should have failed")))

  (let-do [res (CLI.App.parse-from &git &[])]
    (match res
      (CLI.Dispatch.Failure e)
        (assert-equal test
          "No subcommand given."
          &e
          "App reports a missing subcommand")
      _ (assert-true test false "missing subcommand should have failed")))

  (let-do [res (CLI.App.parse-from &git &[@"commit"])]
    (match res
      (CLI.Dispatch.Failure e)
        (assert-equal test
          "Required option missing: --message"
          &e
          "a subcommand’s own parse error propagates")
      _ (assert-true test false "missing required option should have failed")))

  (let-do [res (CLI.App.parse-from &git &[@"--help"])]
    (match res
      (CLI.Dispatch.AppHelp)
        (assert-true test true "App surfaces top-level --help as AppHelp")
      _ (assert-true test false "--help should have yielded AppHelp")))

  ; contextual help: a subcommand’s own --help/-h must be distinguishable from
  ; app-level help so the caller can show that subcommand’s usage, not the app’s
  (let-do [res (CLI.App.parse-from &git &[@"commit" @"--help"])]
    (match res
      (CLI.Dispatch.CommandHelp name)
        (assert-equal test
          "commit"
          &name
          "a subcommand’s --help yields CommandHelp naming that subcommand")
      _ (assert-true test false "commit --help should have yielded CommandHelp")))

  (let-do [res (CLI.App.parse-from &git &[@"push" @"-h"])]
    (match res
      (CLI.Dispatch.CommandHelp name)
        (assert-equal test
          "push"
          &name
          "a subcommand’s -h also yields CommandHelp naming that subcommand")
      _ (assert-true test false "push -h should have yielded CommandHelp")))

  (let-do [res (CLI.App.parse-from &git &[@"-x"])]
    (match res
      (CLI.Dispatch.Failure e)
        (assert-equal test
          "Expected a subcommand, got option: -x"
          &e
          "App rejects a leading option that is not a subcommand")
      _ (assert-true test false "leading option should have failed"))))
